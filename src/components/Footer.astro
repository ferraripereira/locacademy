---
const year = new Date().getFullYear();
---

<footer class="border-t border-border-subtle mt-20">
  <div class="container-page py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
      <div class="md:col-span-1">
        <div class="flex flex-col leading-none mb-3">
          <span class="text-xl font-bold tracking-tight text-text-primary">LocAcademy</span>
          <span class="text-xs text-text-muted font-normal mt-0.5">by ODuo</span>
        </div>
        <p class="text-sm text-text-muted leading-relaxed mt-4 mb-6">
          Educação prática pra dono de locadora de equipamentos. Sem teoria de palestra.
        </p>
        {/* Logo ODuo: usa PNG quando Lucas salvar em public/logos/oduo-white.png. Ate la, fallback texto. */}
        <a href="https://oduo.com.br" class="inline-flex items-center gap-2 text-text-muted hover:text-text-primary text-xs">
          <span>Um produto da</span>
          <img
            src="/logos/oduo-white.png"
            alt="ODuo"
            class="h-6 w-auto opacity-70"
            onerror="this.style.display='none'; this.nextElementSibling.style.display='inline';"
          />
          <span style="display:none;" class="font-bold text-text-primary">ODuo</span>
        </a>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-text-primary mb-4">LocAcademy</h4>
        <ul class="space-y-3 text-sm">
          <li><a href="/" class="text-text-muted hover:text-text-primary">Home</a></li>
          <li><a href="/curso" class="text-text-muted hover:text-text-primary">Curso</a></li>
          <li><a href="/sobre" class="text-text-muted hover:text-text-primary">Sobre</a></li>
          <li><a href="/blog" class="text-text-muted hover:text-text-primary">Blog</a></li>
          <li><a href="/cadastro" class="text-text-muted hover:text-text-primary">Cadastro</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-text-primary mb-4">ODuo</h4>
        <ul class="space-y-3 text-sm">
          <li><a href="https://oduo.com.br" class="text-text-muted hover:text-text-primary">Site institucional</a></li>
          <li><a href="https://instagram.com/oduomarketing" class="text-text-muted hover:text-text-primary">Instagram</a></li>
          <li><a href="https://linkedin.com" class="text-text-muted hover:text-text-primary">LinkedIn</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-text-primary mb-4">Contato</h4>
        <ul class="space-y-3 text-sm">
          <li class="text-text-muted">contato@oduo.com.br</li>
          <li class="text-text-muted">Campinas / SP</li>
        </ul>
      </div>
    </div>

    <div class="border-t border-border-subtle mt-12 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-text-muted">
        LocAcademy by ODuo &middot; &copy; {year} &middot; Todos os direitos reservados.
      </p>
      <div class="flex gap-6 text-xs">
        <a href="/politicas/privacidade" class="text-text-muted hover:text-text-primary">
          Política de Privacidade
        </a>
        <a href="/politicas/termos" class="text-text-muted hover:text-text-primary">
          Termos de Uso
        </a>
      </div>
    </div>
  </div>
</footer>
