---
interface Props {
  size?: 'sm' | 'md' | 'lg';
}

const { size = 'md' } = Astro.props;

const sizes = {
  sm: { img: 'h-7', text: 'text-base' },
  md: { img: 'h-9', text: 'text-lg' },
  lg: { img: 'h-12', text: 'text-2xl' },
};

const cls = sizes[size];
---

<a href="/" class="inline-flex items-center gap-3 leading-none">
  <img
    src="/logos/oduo-white.png"
    alt="ODuo"
    class={`${cls.img} w-auto`}
  />
  <span class={`${cls.text} font-medium text-text-secondary tracking-tight`}>
    Academy
  </span>
</a>
