---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout
  title="Página não encontrada — LocAcademy"
  description="A página que você procura não existe. Volte para a home ou conheça o curso."
  noindex={true}
>
  <section class="container-page pt-32 pb-32 lg:pt-40 lg:pb-40">
    <div class="max-w-2xl mx-auto text-center">
      <p class="display text-brand-accent font-extrabold text-2xl tracking-widest mb-6">404</p>
      <h1 class="display text-5xl sm:text-6xl lg:text-7xl font-extrabold text-text-primary leading-tight tracking-tight">
        Página não encontrada.
      </h1>
      <p class="mt-8 text-lg text-text-secondary leading-relaxed">
        O link tá quebrado ou o endereço tá errado. Mas tá tudo bem — você pode voltar pra casa
        ou ir direto pro curso.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <Button href="/" size="lg">Voltar pra home</Button>
        <Button href="/curso" variant="outline" size="lg">Ver o curso</Button>
      </div>
    </div>
  </section>
</BaseLayout>
