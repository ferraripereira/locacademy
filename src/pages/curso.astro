---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

const howItWorks = [
  {
    step: '01',
    title: 'Cadastra-se',
    text: 'Preenche um formulário rápido com seus dados e da sua locadora.',
  },
  {
    step: '02',
    title: 'Recebe o acesso',
    text: 'A gente libera o curso na sua conta em poucos minutos.',
  },
  {
    step: '03',
    title: 'Estuda no seu ritmo',
    text: 'Vídeos curtos, vai e vem quando quiser.',
  },
  {
    step: '04',
    title: 'Aplica de verdade',
    text: 'Cada aula termina com algo prático pra fazer na sua locadora.',
  },
];

const modules = [
  {
    number: '01',
    title: 'GESTÃO',
    instructor: 'Com Murilo',
    lessons: [
      'Pesquisa de Mercado',
      'Alinhamento de Sócios',
      'Conceito de Estratégia',
      'Conselheiros Estratégicos',
      'Plano Estratégico',
      'Organograma',
      'Marketing Estratégico',
    ],
    outcomes: [
      'Sair do operacional e enxergar a locadora como um negócio',
      'Definir uma estratégia clara que guia decisão do dia-a-dia',
      'Estruturar a empresa pra escalar sem depender só de você',
    ],
  },
  {
    number: '02',
    title: 'VENDAS',
    instructor: 'Com João',
    lessons: [
      'Mentalidade de Vendas',
      'Ativos para Locação',
      'Organização Comercial',
    ],
    outcomes: [
      'Tirar o time comercial do reativo e colocar em ofensivo',
      'Saber quais são os ativos de venda que toda locadora precisa ter',
      'Organizar o processo comercial pra parar de depender do "feeling"',
    ],
  },
  {
    number: '03',
    title: 'MARKETING DIGITAL',
    instructor: 'Com Lucas',
    lessons: [
      'Funil Digital',
      'Lógica de Compra',
      'Google Ads na Prática',
      'Otimização do Google Ads',
      'Life Time Value',
    ],
    outcomes: [
      'Entender o funil digital aplicado ao nicho de locação',
      'Rodar Google Ads sem queimar dinheiro (e medir o que volta)',
      'Calcular LTV pra saber quanto pode investir pra adquirir cliente',
    ],
  },
];
---

<BaseLayout
  title="Curso LocAcademy — Marketing, Vendas e Gestão pra Locadoras | by ODuo"
  description="3 módulos diretos ao ponto, linguagem de quem vive o dia-a-dia da locação. Acesso 100% gratuito enquanto estiver em fase de MVP."
>
  <!-- HERO -->
  <section class="container-page pt-20 pb-16 lg:pt-28 lg:pb-20">
    <div class="max-w-4xl">
      <h1 class="display text-4xl sm:text-5xl lg:text-6xl font-extrabold text-text-primary leading-tight tracking-tight">
        Curso LocAcademy — Marketing, Vendas e Gestão pra Locadoras
      </h1>
      <p class="mt-6 text-lg lg:text-xl text-text-secondary leading-relaxed">
        3 módulos. Linguagem de quem vive o dia-a-dia da locação. Sem firula.
      </p>
      <div class="mt-8 inline-flex flex-wrap items-baseline gap-x-3 gap-y-1 p-4 bg-feedback-success/15 border border-feedback-success/40 rounded-lg">
        <span class="display text-3xl font-extrabold text-feedback-success">GRATUITO</span>
        <span class="text-sm text-text-muted">por tempo limitado</span>
        <span class="text-sm text-text-muted">·</span>
        <span class="text-sm text-text-secondary line-through">R$ 1.997</span>
      </div>
      <div class="mt-6">
        <Button href="/cadastro" size="lg">Garantir meu acesso</Button>
        <p class="mt-3 text-sm text-text-muted">Acesso liberado pela Hotmart · Sem cartão · Sem pegadinha</p>
      </div>
    </div>
  </section>

  <!-- COMO FUNCIONA -->
  <section class="section bg-bg-elevated/30">
    <div class="container-page">
      <h2 class="text-3xl lg:text-4xl font-bold text-text-primary mb-12">Como funciona</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          howItWorks.map((step) => (
            <div class="p-6 bg-bg-elevated border border-border-subtle rounded-lg">
              <div class="display text-3xl font-extrabold text-brand-accent mb-3">{step.step}</div>
              <h3 class="text-lg font-semibold text-text-primary mb-2">{step.title}</h3>
              <p class="text-text-secondary text-sm leading-relaxed">{step.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- DETALHE DOS MÓDULOS -->
  <section class="section">
    <div class="container-page">
      <h2 class="text-3xl lg:text-4xl font-bold text-text-primary mb-12">O conteúdo</h2>
      <div class="space-y-8">
        {
          modules.map((mod) => (
            <div class="p-8 lg:p-10 bg-bg-elevated border border-border-subtle rounded-lg">
              <div class="flex flex-col lg:flex-row lg:items-start gap-8">
                <div class="lg:w-1/3">
                  <span class="text-brand-accent text-sm font-mono">MÓDULO {mod.number}</span>
                  <h3 class="text-3xl font-bold text-text-primary mt-2">{mod.title}</h3>
                  <p class="text-text-muted text-sm mt-2">{mod.instructor}</p>
                </div>
                <div class="lg:w-2/3 space-y-6">
                  <div>
                    <h4 class="text-sm font-semibold text-text-primary uppercase tracking-wide mb-3">
                      Aulas
                    </h4>
                    <ul class="space-y-2">
                      {mod.lessons.map((lesson, idx) => (
                        <li class="flex gap-3 text-text-secondary">
                          <span class="text-brand-accent text-sm font-mono w-6">
                            {String(idx + 1).padStart(2, '0')}
                          </span>
                          <span>{lesson}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div>
                    <h4 class="text-sm font-semibold text-text-primary uppercase tracking-wide mb-3">
                      O que você vai saber fazer
                    </h4>
                    <ul class="space-y-2">
                      {mod.outcomes.map((outcome) => (
                        <li class="flex gap-3 text-text-secondary">
                          <span class="text-brand-accent">→</span>
                          <span>{outcome}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- PRÉ-REQUISITOS -->
  <section class="section bg-bg-elevated/30">
    <div class="container-page">
      <div class="max-w-3xl">
        <h2 class="text-3xl lg:text-4xl font-bold text-text-primary mb-6">
          O que você precisa pra começar
        </h2>
        <p class="text-lg text-text-secondary leading-relaxed">
          Nada. Sério. Você precisa ter uma locadora (ou trabalhar em uma) e vontade de aprender.
          O curso foi pensado pra quem nunca sentou pra estudar gestão na vida.
        </p>
      </div>
    </div>
  </section>

  <!-- POR QUE ESTA GRATUITO -->
  <section class="section">
    <div class="container-page">
      <div class="max-w-3xl">
        <h2 class="text-3xl lg:text-4xl font-bold text-text-primary mb-6">Por que tá de graça?</h2>
        <p class="text-lg text-text-secondary leading-relaxed mb-4">
          A ODuo trabalha com mais de 500 locadoras todos os dias e a gente condensou 7 anos de
          mercado nesses 3 módulos. O valor cheio do curso completo é
          <strong class="text-text-primary">R$ 1.997</strong>.
        </p>
        <p class="text-lg text-text-secondary leading-relaxed mb-4">
          Mas a gente tá numa fase de testar o conteúdo com donos de locadora reais antes de
          escalar. Por isso, durante essa janela, o acesso aos 3 primeiros módulos está
          <strong class="text-text-primary">100% liberado de graça</strong>.
        </p>
        <p class="text-lg text-text-secondary leading-relaxed">
          Quando o curso completo entrar no ar, o acesso fecha e passa a ser pago. <strong class="text-text-primary">Quem
          entra agora aproveita enquanto está aberto.</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="section">
    <div class="container-page text-center">
      <Button href="/cadastro" size="lg">Garantir meu acesso gratuito</Button>
      <p class="mt-4 text-sm text-text-muted">Acesso liberado pela Hotmart · Sem cartão · Sem pegadinha</p>
    </div>
  </section>
</BaseLayout>
