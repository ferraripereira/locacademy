---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

const testimonials = [
  {
    quote: 'Investimos na ODuo e o resultado foi impressionante: mais de R$ 210.000,00 em locações fechadas. Além do retorno financeiro, tivemos clareza no processo, agilidade nas entregas e um atendimento que realmente entende do nosso mercado.',
    name: 'Cristiano',
    company: 'CLM Locações',
    role: 'Proprietário',
  },
  {
    quote: 'A ODuo abriu nossos olhos para nos posicionarmos digitalmente. Junto com eles, conseguimos números positivos em nossas campanhas em 2024 e em 2025 esperamos fortalecer ainda mais os nossos resultados. A equipe é muito dedicada e encara o desafio com muito entusiasmo.',
    name: 'Equipe',
    company: 'Centro Aço',
    role: '',
  },
  {
    quote: 'São pessoas novas, mas que trazem muita experiência, que trazem muito conhecimento. Então a gente tá nessa caminhada junto, torcendo e esperando que a gente conquiste coisas grandes no futuro juntos.',
    name: 'Equipe',
    company: 'RTE Andaimes',
    role: '',
  },
];

const clientLogos = [
  { name: 'RTE Andaimes', src: '/clientes/logo-rte-andaimes.png' },
  { name: 'Aliança Betoneiras', src: '/clientes/logo-alianca-betoneiras.webp' },
  { name: 'CLM Locações', src: '/clientes/logo-clm.png' },
  { name: 'Centro Aço', src: '/clientes/logo_centro-aco.png' },
  { name: 'FEL', src: '/clientes/logo-fel.png' },
  { name: 'Techlift', src: '/clientes/logo-techlift.png' },
  { name: 'K-Rental', src: '/clientes/logo-k-rental.png' },
  { name: 'Adap', src: '/clientes/logo-adap.png' },
  { name: 'Assis Rental', src: '/clientes/logo-assis-rental.png' },
  { name: 'Mestre da Obra', src: '/clientes/logo-mestre-da-obra.png' },
];

const instructors = [
  {
    name: 'Murilo',
    role: 'CEO e Co-fundador da ODuo · Instrutor do Módulo 1 — Gestão',
    bio: 'Murilo é o CEO e co-fundador da ODuo Assessoria. É ele quem lidera a estratégia, a cultura e os métodos de gestão que a ODuo aplica em mais de 500 locadoras pelo Brasil. Mais do que dar palpite, foi quem desenhou o caminho que tirou a ODuo do zero ao patamar atual — e é exatamente esse método que ele ensina no Módulo de Gestão.',
    photo: '/fotos/murilo.jpg',
  },
  {
    name: 'João',
    role: 'Sócio da ODuo · Instrutor do Módulo 2 — Vendas',
    bio: 'João é sócio da ODuo e o cara que cuida do comercial dentro da casa. São mais de 5 anos estruturando processo de vendas no nicho de locação — não é venda genérica de "consultor de palco", é o que funciona quando o cliente é dono de locadora. No Módulo de Vendas ele passa o método que usa todos os dias com os clientes da ODuo.',
    photo: '/fotos/joao.jpg',
  },
  {
    name: 'Lucas Pereira',
    role: 'Co-fundador da ODuo · Instrutor do Módulo 3 — Marketing Digital',
    bio: 'Co-fundador da ODuo e especialista em marketing pra locadora de equipamentos. Mais de 6 anos trabalhando exclusivamente com esse nicho — Google Ads, posicionamento digital, funil de vendas pra B2B de locação. É isso que ele entrega no Módulo de Marketing Digital: o que funciona na prática, com base no que está sendo aplicado em centenas de locadoras-cliente da ODuo agora.',
    photo: '/fotos/lucas.jpg',
  },
];
---

<BaseLayout
  title="Sobre o LocAcademy — Quem está por trás da escola | by ODuo"
  description="LocAcademy nasceu dentro da ODuo, assessoria 100% focada em locadoras de equipamentos. Conheça quem está por trás do projeto."
>
  <!-- HERO -->
  <section class="container-page pt-20 pb-16 lg:pt-28 lg:pb-20">
    <div class="max-w-4xl">
      <h1 class="display text-4xl sm:text-5xl lg:text-6xl font-extrabold text-text-primary leading-tight tracking-tight">
        Quem tá por trás do LocAcademy
      </h1>
      <p class="mt-6 text-lg lg:text-xl text-text-secondary leading-relaxed">
        LocAcademy nasceu dentro da ODuo — assessoria de marketing, vendas e tecnologia 100%
        focada em locadoras de equipamentos.
      </p>
    </div>
  </section>

  <!-- A ODUO -->
  <section class="section bg-bg-elevated/30">
    <div class="container-page">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl lg:text-4xl font-bold text-text-primary mb-8">A ODuo</h2>
          <div class="space-y-5 text-lg text-text-secondary leading-relaxed">
            <p>
              A ODuo é a casa que ajuda locadora de equipamentos a vender mais e operar melhor.
              Marketing, tecnologia e inteligência artificial, tudo aplicado ao nicho de locação —
              e só ao nicho de locação.
            </p>
            <p>
              Hoje a gente atende mais de <strong class="text-text-primary">500 locadoras</strong>
              espalhadas pelo Brasil. Da locadora pequena de bairro até operações com frota de
              centenas de equipamentos. A gente aprendeu, na prática, o que funciona e o que não
              funciona pra esse mercado.
            </p>
            <p>
              O LocAcademy é a forma da gente compartilhar isso com quem ainda não é cliente — ou
              com quem é cliente e quer afundar mais ainda no conhecimento.
            </p>
          </div>
        </div>
        <div class="rounded-xl border border-border-subtle overflow-hidden bg-bg-subtle">
          <img
            src="/fotos/lucas-murilo.jpg"
            alt="Lucas Pereira e Murilo — co-fundadores da ODuo"
            class="w-full h-auto object-contain"
            loading="lazy"
          />
        </div>
      </div>
      <div class="mt-12 max-w-3xl">
        <div>
          <a
            href="https://oduo.com.br"
            class="text-brand-accent hover:text-text-primary font-medium inline-flex items-center gap-2"
          >
            Conhecer a ODuo
            <span>→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- POR QUE EXISTE -->
  <section class="section">
    <div class="container-page">
      <div class="max-w-3xl">
        <h2 class="text-3xl lg:text-4xl font-bold text-text-primary mb-8">Por que esse curso existe</h2>
        <div class="space-y-5 text-lg text-text-secondary leading-relaxed">
          <p>
            Toda vez que a gente entrava numa locadora nova como cliente, batia na mesma realidade:
            o dono é um craque em operação e atendimento, mas nunca recebeu educação formal sobre
            como gerir o negócio, como vender com método ou como fazer marketing.
          </p>
          <p>
            Não é por falta de capacidade. É por falta de acesso. O conteúdo de gestão que existe é
            genérico — fala de "empresa" em abstrato, não fala da realidade de quem aluga compactador
            e betoneira.
          </p>
          <p>
            A gente decidiu fazer o conteúdo que a gente queria que existisse quando começou
            nesse mercado.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- INSTRUTORES -->
  <section class="section bg-bg-elevated/30">
    <div class="container-page">
      <h2 class="text-3xl lg:text-4xl font-bold text-text-primary mb-12">Quem vai te ensinar</h2>
      <div class="space-y-12">
        {
          instructors.map((inst, idx) => (
            <div class={`flex flex-col ${idx % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-10 items-start`}>
              <div class="lg:w-1/3">
                <div class="aspect-square bg-bg-subtle rounded-lg overflow-hidden">
                  <img
                    src={inst.photo}
                    alt={`Foto de ${inst.name}`}
                    class="w-full h-full object-cover object-top"
                    loading="lazy"
                  />
                </div>
              </div>
              <div class="lg:w-2/3">
                <h3 class="text-3xl font-bold text-text-primary mb-2">{inst.name}</h3>
                <p class="text-brand-accent font-medium mb-4">{inst.role}</p>
                <p class="text-lg text-text-secondary leading-relaxed">{inst.bio}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- DEPOIMENTOS DE CLIENTES ODUO -->
  <section class="section bg-bg-elevated/30">
    <div class="container-page">
      <div class="max-w-3xl mb-12">
        <span class="inline-block text-brand-accent text-sm font-mono mb-3">O QUE OS CLIENTES DIZEM</span>
        <h2 class="text-3xl lg:text-4xl font-bold text-text-primary mb-6">
          Não somos nós dizendo que funciona. São eles.
        </h2>
        <p class="text-lg text-text-secondary leading-relaxed">
          O LocAcademy condensa o método que a ODuo aplica nesses clientes todo dia.
          Esses depoimentos são da operação ODuo — quem entra no LocAcademy aprende exatamente
          o que está sendo entregue pra eles.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {testimonials.map((t) => (
          <figure class="p-8 bg-bg-elevated border border-border-subtle rounded-lg flex flex-col">
            <div class="text-brand-accent text-4xl font-serif leading-none mb-4">"</div>
            <blockquote class="text-text-secondary leading-relaxed mb-6 flex-grow">
              {t.quote}
            </blockquote>
            <figcaption class="pt-4 border-t border-border-subtle">
              <p class="text-text-primary font-semibold">{t.name}</p>
              <p class="text-sm text-text-muted">
                {t.role && <span>{t.role} · </span>}
                <span class="text-brand-accent">{t.company}</span>
              </p>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- LOGOS DE CLIENTES -->
  <section class="section">
    <div class="container-page">
      <div class="max-w-3xl mb-10">
        <h3 class="text-2xl lg:text-3xl font-bold text-text-primary mb-4">
          Algumas locadoras que a ODuo atende
        </h3>
        <p class="text-text-secondary">
          De norte a sul do Brasil, são +500 locadoras na carteira. Aqui algumas delas:
        </p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
        {clientLogos.map((logo) => (
          <div class="flex items-center justify-center px-6 py-8 bg-bg-elevated border border-border-subtle rounded-lg">
            <img
              src={logo.src}
              alt={`Logo ${logo.name}`}
              class="max-h-12 w-auto opacity-70 hover:opacity-100 transition-opacity"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container-page text-center">
      <p class="text-xl text-text-secondary mb-2">Bora começar?</p>
      <p class="text-text-muted mb-8">Acesso gratuito por tempo limitado</p>
      <Button href="/cadastro" size="lg">Garantir meu acesso gratuito</Button>
    </div>
  </section>
</BaseLayout>
