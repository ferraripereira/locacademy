---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

const modules = [
  {
    number: '01',
    title: 'GESTÃO',
    tagline: 'Pare de tocar sua locadora no escuro.',
    bullets: [
      'Pesquisa de mercado, alinhamento de sócios e plano estratégico',
      'Organograma e papéis claros (sem você fazendo tudo)',
      'Conselheiros estratégicos: quem te puxa pra cima',
    ],
  },
  {
    number: '02',
    title: 'VENDAS',
    tagline: 'Sai do reativo. Entra no ofensivo.',
    bullets: [
      'Mentalidade de vendas que toda locadora competitiva tem',
      'Os ativos comerciais que sua locadora precisa ter (e quase nenhuma tem)',
      'Como organizar o time pra parar de depender do "feeling"',
    ],
  },
  {
    number: '03',
    title: 'MARKETING DIGITAL',
    tagline: 'Vire a locadora que o cliente acha primeiro.',
    bullets: [
      'O funil digital aplicado ao nicho de locação (não é genérico)',
      'Google Ads na prática + otimização (sem queimar dinheiro)',
      'LTV: quanto você pode investir pra capturar cada cliente',
    ],
  },
];

const instructors = [
  {
    name: 'Murilo',
    role: 'CEO e co-fundador da ODuo · Módulo de Gestão',
    photo: '/fotos/murilo.jpg',
  },
  {
    name: 'João',
    role: 'Sócio da ODuo · Módulo de Vendas',
    photo: '/fotos/joao.jpg',
  },
  {
    name: 'Lucas Pereira',
    role: 'Co-fundador da ODuo · Módulo de Marketing',
    photo: '/fotos/lucas.jpg',
  },
];

const problems = [
  {
    icon: '💸',
    title: 'Você trabalha muito e não escala',
    text: 'A locadora cresce, o trabalho aumenta, mas a margem fica igual. Você sente que se parar uma semana, tudo desmorona.',
  },
  {
    icon: '📵',
    title: 'Concorrente bobo te ganha cliente',
    text: 'Aquele cara que mal sabe atender, mas tem o Google bem feito, leva orçamento que era seu. E você fica olhando.',
  },
  {
    icon: '⏳',
    title: 'Vende quem chega — e só',
    text: 'Sua locadora vive de quem manda mensagem espontânea. Quando essa torneira fecha, o mês fica vermelho. Sem saída.',
  },
];

const audience = [
  'Você é dono, sócio ou braço-direito de uma locadora de equipamentos',
  'Sua locadora fatura — mas você sente que poderia faturar muito mais',
  'Você nunca recebeu treinamento formal de gestão, vendas ou marketing',
  'Você está cansado de competir só por preço (e ver margem evaporar)',
  'Você quer parar de "tocar a empresa" e começar a "liderar o negócio"',
];

const stats = [
  { value: '+500', label: 'Locadoras atendidas pela ODuo' },
  { value: '7 anos', label: 'de mercado' },
  { value: 'R$ 185M', label: 'em vendas geradas pra clientes' },
  { value: '+19k', label: 'leads gerados' },
];

// Modelo atual: curso vale R$ 1.997, mas esta GRATUITO durante o MVP (3 modulos).
// Quem entra agora perde acesso quando virar pago.
const valorReal = 'R$ 1.997';
const heroImage = 'https://images.unsplash.com/photo-1541888946425-d81bb19240f5?w=1600&q=80&auto=format&fit=crop';
const problemImage = 'https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=1200&q=80&auto=format&fit=crop';

const courseJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: 'LocAcademy — Marketing, Vendas e Gestão pra Locadoras',
  description:
    'Curso para donos de locadora de equipamentos. 3 módulos: Gestão, Vendas e Marketing aplicados ao nicho de locação. Acesso gratuito por tempo limitado durante a fase de validação.',
  provider: {
    '@type': 'EducationalOrganization',
    name: 'LocAcademy by ODuo',
    sameAs: 'https://academy.oduo.com.br',
  },
  inLanguage: 'pt-BR',
  educationalLevel: 'Beginner',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'BRL',
    availability: 'https://schema.org/InStock',
  },
  hasCourseInstance: {
    '@type': 'CourseInstance',
    courseMode: 'online',
  },
};
---

<BaseLayout>
  <script type="application/ld+json" set:html={JSON.stringify(courseJsonLd)} />

  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="container-page pt-24 pb-20 lg:pt-32 lg:pb-28 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <span class="inline-flex items-center gap-2 px-3 py-1 bg-feedback-success/15 text-feedback-success text-xs font-medium rounded-full mb-6">
          ● {valorReal} · liberado de graça por tempo limitado
        </span>
        <h1 class="display text-4xl sm:text-5xl lg:text-6xl font-extrabold text-text-primary leading-[1.05] tracking-tight">
          O método que tirou +500 locadoras do improviso. Agora aberto pra você.
        </h1>
        <p class="mt-8 text-lg lg:text-xl text-text-secondary leading-relaxed">
          LocAcademy é o primeiro curso 100% feito pra dono de locadora de equipamentos.
          7 anos da ODuo aplicando o que funciona — gestão, vendas e marketing digital —
          condensados em 3 módulos diretos ao ponto.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <Button href="/cadastro" size="lg">Quero acessar agora</Button>
          <Button href="/curso" variant="outline" size="lg">Ver o que tem dentro</Button>
        </div>
        <p class="mt-6 text-sm text-text-muted">
          Sem cartão · Sem pegadinha · Acesso imediato no seu e-mail
        </p>
      </div>

      <div class="relative">
        <img
          src={heroImage}
          alt="Equipamento de locação em canteiro de obra"
          class="w-full aspect-[4/5] object-cover rounded-xl border border-border-subtle"
          loading="eager"
        />
        <div class="absolute -bottom-6 -left-6 p-6 bg-bg-elevated border border-border-strong rounded-lg shadow-2xl max-w-[260px]">
          <div class="flex items-baseline gap-2 mb-2">
            <span class="display text-3xl font-extrabold text-brand-accent">3</span>
            <span class="text-text-secondary text-sm">módulos completos</span>
          </div>
          <p class="text-xs text-text-muted">Gestão, Vendas e Marketing aplicados ao seu nicho</p>
        </div>
      </div>
    </div>

    <!-- gradiente sutil de fundo -->
    <div class="absolute inset-0 -z-10 pointer-events-none">
      <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-brand-primary/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-brand-accent/5 rounded-full blur-3xl"></div>
    </div>
  </section>

  <!-- PROBLEMA -->
  <section class="section bg-bg-elevated/30 relative overflow-hidden">
    <div
      class="absolute inset-y-0 right-0 w-1/2 bg-cover bg-center opacity-10 pointer-events-none hidden lg:block"
      style={`background-image: url(${problemImage})`}
    ></div>
    <div class="container-page relative">
      <div class="max-w-3xl mb-16">
        <h2 class="text-3xl lg:text-5xl font-bold text-text-primary mb-6">
          Toda locadora trava nos mesmos 3 lugares. Você reconhece?
        </h2>
        <p class="text-lg text-text-secondary leading-relaxed">
          A gente entra em 30 locadoras por mês na ODuo. E todas têm os mesmos buracos —
          quem cresce é quem decide tampar. Antes de te falar do conteúdo do curso,
          olha se você se enxerga aqui:
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {
          problems.map((problem) => (
            <div class="p-8 bg-bg-elevated border border-border-subtle rounded-lg">
              <div class="text-3xl mb-4">{problem.icon}</div>
              <h3 class="text-xl font-semibold text-text-primary mb-3">{problem.title}</h3>
              <p class="text-text-secondary leading-relaxed">{problem.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- MÓDULOS -->
  <section class="section">
    <div class="container-page">
      <div class="max-w-3xl mb-16">
        <span class="inline-block text-brand-accent text-sm font-mono mb-3">O QUE TEM DENTRO</span>
        <h2 class="text-3xl lg:text-5xl font-bold text-text-primary mb-6">
          3 módulos. 15 aulas. Zero teoria de palestra.
        </h2>
        <p class="text-lg text-text-secondary leading-relaxed">
          Cada módulo é o que a ODuo aplica todo dia dentro dos clientes. Você assiste,
          aplica na sua locadora na mesma semana, e vê resultado.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {
          modules.map((mod) => (
            <div class="p-8 bg-bg-elevated border border-border-subtle rounded-lg hover:border-brand-accent/50 transition-colors">
              <span class="text-brand-accent text-sm font-mono">MÓDULO {mod.number}</span>
              <h3 class="text-2xl font-bold text-text-primary mt-2 mb-2">{mod.title}</h3>
              <p class="text-brand-accent text-sm italic mb-6">{mod.tagline}</p>
              <ul class="space-y-3">
                {mod.bullets.map((bullet) => (
                  <li class="flex gap-3 text-text-secondary text-sm leading-relaxed">
                    <span class="text-brand-accent mt-1">→</span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <div class="mt-12 text-center">
        <Button href="/cadastro" size="lg">Garantir meu acesso gratuito</Button>
        <p class="mt-4 text-sm text-text-muted">
          Valor de {valorReal} — liberado de graça enquanto durar a fase de validação
        </p>
      </div>
    </div>
  </section>

  <!-- INSTRUTORES -->
  <section class="section bg-bg-elevated/30">
    <div class="container-page">
      <div class="max-w-3xl mb-16">
        <span class="inline-block text-brand-accent text-sm font-mono mb-3">QUEM ENSINA</span>
        <h2 class="text-3xl lg:text-5xl font-bold text-text-primary mb-6">
          Não é professor de business school. É quem tá na operação todo dia.
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {
          instructors.map((inst) => (
            <div class="text-center">
              <div class="aspect-square bg-bg-subtle rounded-lg overflow-hidden mb-6">
                <img
                  src={inst.photo}
                  alt={`Foto de ${inst.name}`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
              <h3 class="text-xl font-bold text-text-primary mb-2">{inst.name}</h3>
              <p class="text-text-muted text-sm">{inst.role}</p>
            </div>
          ))
        }
      </div>

      <blockquote class="max-w-3xl mx-auto mt-16 text-center">
        <p class="text-xl text-text-secondary italic leading-relaxed">
          "A gente atende +500 locadoras no Brasil. Tudo que tá no LocAcademy é o que a gente
          aplica dentro dessas operações pra fazer elas crescerem. Não é teoria. É o método."
        </p>
      </blockquote>
    </div>
  </section>

  <!-- PRA QUEM É -->
  <section class="section">
    <div class="container-page">
      <div class="max-w-3xl">
        <span class="inline-block text-brand-accent text-sm font-mono mb-3">PRA QUEM É</span>
        <h2 class="text-3xl lg:text-5xl font-bold text-text-primary mb-10">
          O LocAcademy é seu se você se enxerga em alguma dessas:
        </h2>
        <ul class="space-y-4">
          {
            audience.map((item) => (
              <li class="flex gap-4 text-lg text-text-secondary">
                <span class="text-brand-accent text-2xl leading-none">✓</span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>

        <div class="mt-12 pt-8 border-t border-border-subtle">
          <h3 class="text-xl font-semibold text-text-primary mb-4">Não é pra você se…</h3>
          <ul class="space-y-3">
            <li class="flex gap-4 text-text-muted">
              <span class="text-feedback-error">✗</span>
              <span>Procura fórmula mágica de dobrar faturamento em 30 dias</span>
            </li>
            <li class="flex gap-4 text-text-muted">
              <span class="text-feedback-error">✗</span>
              <span>Não tá disposto a dedicar 30 minutos por dia pra aplicar o que aprende</span>
            </li>
            <li class="flex gap-4 text-text-muted">
              <span class="text-feedback-error">✗</span>
              <span>Acha que "marketing é só rede social" e que "vendas é só preço bom"</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- PROVA SOCIAL -->
  <section class="section bg-bg-elevated/30">
    <div class="container-page">
      <div class="max-w-3xl mb-16">
        <span class="inline-block text-brand-accent text-sm font-mono mb-3">QUEM ESTÁ POR TRÁS</span>
        <h2 class="text-3xl lg:text-5xl font-bold text-text-primary mb-6">
          A casa que mais entende de locadora no Brasil.
        </h2>
        <p class="text-lg text-text-secondary leading-relaxed">
          O LocAcademy não nasceu numa sala de aula. Nasceu dentro da ODuo, depois de
          7 anos atendendo locadora todo dia. Os números falam por si:
        </p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {
          stats.map((stat) => (
            <div class="p-8 bg-bg-elevated border border-border-subtle rounded-lg text-center">
              <div class="display text-4xl lg:text-5xl font-extrabold text-brand-accent">
                {stat.value}
              </div>
              <p class="text-sm text-text-muted mt-3 leading-tight">{stat.label}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="section">
    <div class="container-page">
      <div class="max-w-3xl mx-auto text-center p-12 lg:p-16 bg-gradient-to-br from-brand-primary/20 to-brand-accent/10 border border-border-strong rounded-xl">
        <h2 class="text-3xl lg:text-5xl font-bold text-text-primary mb-6">
          Aproveita — não vai ser de graça pra sempre.
        </h2>
        <p class="text-lg text-text-secondary leading-relaxed mb-2">
          O curso completo vai custar <strong class="text-text-primary">{valorReal}</strong>.
          Hoje, está liberado de graça pra quem entrar agora.
        </p>
        <p class="text-base text-text-secondary leading-relaxed mb-10">
          Em algumas semanas a gente fecha o acesso e começa a cobrar. Quem entrou na fase gratuita
          aproveita enquanto está aberto.
        </p>
        <Button href="/cadastro" size="lg">Garantir meu acesso gratuito</Button>
        <p class="mt-6 text-sm text-text-muted">
          Acesso liberado direto pela Hotmart · Sem cartão de crédito · Sem pegadinha
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
